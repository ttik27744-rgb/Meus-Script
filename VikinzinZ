local Tab1 = Window:CreateTab("🔻 Rastrejar", 4483362458)

Tab1:CreateToggle({
   Name = "Modo Rastrejar",
   CurrentValue = false,
   Callback = function(v)
      _G.Config.ModoFissura = v
      BotaoSubir.Visible = v
      BotaoDescer.Visible = v
      
      if v then
         local char = lp.Character
         local root = char and char:FindFirstChild("HumanoidRootPart")
         local hum = char and char:FindFirstChildOfClass("Humanoid")
         
         if root and hum then
            _G.Config.AlturaFissura = root.Position.Y - 4.5
            
            task.spawn(function()
               local anims = hum:FindFirstChild("Animator")
               if anims then anims.Name = "Animator_Paused" end
               
               while _G.Config.ModoFissura do
                  root.Velocity = Vector3.zero
                  local moveDir = hum.MoveDirection
                  
                  if moveDir.Magnitude > 0 then
                     root.CFrame = root.CFrame + (moveDir * _G.Config.VelocidadeRastejar)
                  end
                  
                  root.CFrame = CFrame.new(root.Position.X, _G.Config.AlturaFissura, root.Position.Z) * CFrame.Angles(0, math.rad(root.Rotation.Y), 0)
                  hum:ChangeState(Enum.HumanoidStateType.Physics)
                  
                  for _, part in pairs(char:GetDescendants()) do
                     if part:IsA("BasePart") then part.CanCollide = false end
                  end
                  
                  RunService.Stepped:Wait()
               end
               
               local ap = hum:FindFirstChild("Animator_Paused")
               if ap then ap.Name = "Animator" end
               hum:ChangeState(Enum.HumanoidStateType.GettingUp)
            end)
         end
      end
   end
})

