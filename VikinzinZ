local function verificarRaridade(raridades)
    local rep = game:GetService("ReplicatedStorage")
    
    for _, rar in ipairs(raridades) do
        if rep:FindFirstChild(rar) then return true, rar end
        
        for _, obj in pairs(rep:GetDescendants()) do
            local ok, attr = pcall(function() return obj:GetAttribute("Rarity") end)
            if ok and attr == rar then return true, rar end
        end
    end
    
    local plots = workspace:FindFirstChild("Plots")
    if plots then
        for _, rar in ipairs(raridades) do
            for _, plot in pairs(plots:GetChildren()) do
                for _, obj in pairs(plot:GetDescendants()) do
                    local ok, attr = pcall(function() return obj:GetAttribute("Rarity") end)
                    if ok and attr == rar then return true, rar end
                end
            end
        end
    end
    
    for _, rar in ipairs(raridades) do
        for _, player in pairs(Players:GetPlayers()) do
            local bp = player:FindFirstChild("Backpack")
            if bp then
                for _, item in pairs(bp:GetDescendants()) do
                    local ok, attr = pcall(function() return item:GetAttribute("Rarity") end)
                    if ok and attr == rar then return true, rar end
                end
            end
        end
    end
    
    return false, nil
end

local function pegarServidores()
    local servers = {}
    local url = string.format("https://games.roblox.com/v1/games/%s/servers/Public?limit=100", game.PlaceId)
    local ok, result = pcall(function() return HttpService:JSONDecode(game:HttpGet(url)) end)
    
    if ok and result and result.data then
        for _, srv in ipairs(result.data) do
            if srv.id ~= game.JobId then
                table.insert(servers, srv)
            end
        end
    end
    
    return servers
end

