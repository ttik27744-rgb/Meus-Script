local function DestruirBarreiras()
    local count = 0
    
    local tpFolder = workspace:FindFirstChild("TP_BARRIERS")
    if tpFolder then
        for _, v in pairs(tpFolder:GetDescendants()) do
            if v:IsA("BasePart") or v:IsA("TouchTransmitter") then
                pcall(function()
                    v:Destroy()
                    count = count + 1
                end)
            end
        end
    end
    
    for _, v in pairs(workspace:GetDescendants()) do
        if v.Name == "TP_BARRIERS" or v.Name == "TP_Barrier" then
            pcall(function()
                v:Destroy()
                count = count + 1
            end)
        end
    end
    
    return count
end

