local function AtivarAntiLag()
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return end
    
    local count = 0
    
    for _, plot in pairs(plots:GetChildren()) do
        for _, obj in pairs(plot:GetDescendants()) do
            if obj:IsA("ParticleEmitter") or obj:IsA("Fire") or obj:IsA("Smoke") or 
               obj:IsA("Sparkles") or obj:IsA("Trail") or obj:IsA("Beam") then
                pcall(function()
                    table.insert(ObjetosRemovidos, {obj = obj, parent = obj.Parent})
                    obj.Parent = nil
                    count = count + 1
                end)
            elseif obj:IsA("PointLight") or obj:IsA("SpotLight") or obj:IsA("SurfaceLight") then
                pcall(function()
                    table.insert(ObjetosRemovidos, {obj = obj, parent = obj.Parent})
                    obj.Parent = nil
                    count = count + 1
                end)
            elseif obj:IsA("MeshPart") or obj:IsA("UnionOperation") then
                pcall(function()
                    table.insert(ObjetosRemovidos, {
                        obj = obj,
                        material = obj.Material,
                        reflectance = obj.Reflectance
                    })
                    obj.Material = Enum.Material.SmoothPlastic
                    obj.Reflectance = 0
                    count = count + 1
                end)
            elseif obj:IsA("Decal") or obj:IsA("Texture") then
                pcall(function()
                    table.insert(ObjetosRemovidos, {obj = obj, parent = obj.Parent})
                    obj.Parent = nil
                    count = count + 1
                end)
            end
        end
    end
    
    Rayfield:Notify({
        Title = "⚡ Anti-Lag Ativado",
        Content = count .. " objetos otimizados",
        Duration = 3
    })
end

local function DesativarAntiLag()
    local count = 0
    
    for _, data in pairs(ObjetosRemovidos) do
        pcall(function()
            if data.parent then
                data.obj.Parent = data.parent
            end
            if data.material then
                data.obj.Material = data.material
                data.obj.Reflectance = data.reflectance
            end
            count = count + 1
        end)
    end
    
    ObjetosRemovidos = {}
    
    Rayfield:Notify({
        Title = "✅ Anti-Lag Desativado",
        Content = count .. " objetos restaurados",
        Duration = 3
    })
end

